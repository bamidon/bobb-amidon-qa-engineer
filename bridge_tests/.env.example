# Required for auth tests (npm run test:auth)
# Get these from: https://supabase.com → project → Settings → API

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fixture user credentials (populated by: npx tsx tests/helpers/createFixtureUsers.ts)
FIXTURE_ALICE_EMAIL=fixture-alice@bridge.test
FIXTURE_ALICE_PASSWORD=Bridge-test-2024!
FIXTURE_BOB_EMAIL=fixture-bob@bridge.test
FIXTURE_BOB_PASSWORD=Bridge-test-2024!
